{
    "name": "ai_mask",
    "description": "AI background masking + align + mesh. For objects on cluttered backgrounds.",
    "requires": ["input_folder", "output_project", "output_report"],
    "steps": [
        "-set appQuitOnError=true",
        "-addFolder {input_folder}",
        "-generateAIMasks",
        "-align",
        "-selectMaximalComponent",
        "-setReconstructionRegionAuto",
        "-calculateNormalModel",
        "-selectMarginalTriangles",
        "-removeSelectedTriangles",
        "-save {output_project}",
        "-exportReport {output_report} {overview_template}",
        "-quit"
    ]
}
