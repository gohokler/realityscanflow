{
    "name": "colmap",
    "description": "Align + export to COLMAP format. For Gaussian Splatting or NeRF workflows.",
    "requires": ["input_folder", "output_project", "output_report"],
    "steps": [
        "-set appQuitOnError=true",
        "-addFolder {input_folder}",
        "-align",
        "-selectMaximalComponent",
        "-exportRegistration {output_project}_colmap colmap",
        "-save {output_project}",
        "-exportReport {output_report} {overview_template}",
        "-quit"
    ]
}
