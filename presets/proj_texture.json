{
    "name": "proj_texture",
    "description": "Load existing project with mesh, calculate texture and save. Use with --project-mode.",
    "requires": [
        "input_project",
        "output_project",
        "output_report"
    ],
    "steps": [
        "-set appQuitOnError=true",
        "-importGlobalSettings {global_settings}",
        "-load {input_project}",
        "-selectMaximalComponent",
        "-unwrap",
        "-calculateTexture",
        "-renameSelectedModel {scan_name}_textured",
        "-save {output_project}",
        "-exportReport {output_report} {overview_template}",
        "-quit"
    ]
}