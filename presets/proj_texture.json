{
    "name": "proj_texture",
    "description": "Load existing project with mesh, calculate texture and export OBJ. Use with --project-mode.",
    "requires": ["input_project", "output_project", "output_report"],
    "steps": [
        "-set appQuitOnError=true",
        "-load {input_project}",
        "-selectMaximalComponent",
        "-renameSelectedModel textured_model",
        "-unwrap",
        "-calculateTexture",
        "-exportModel textured_model {output_project}.obj",
        "-save {output_project}",
        "-exportReport {output_report} {overview_template}",
        "-quit"
    ]
}
