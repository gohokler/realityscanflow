{
    "name": "raw_textured",
    "description": "Full pipeline: align + mesh + unwrap + texture and save. Production ready output.",
    "requires": [
        "input_folder",
        "output_project",
        "output_report"
    ],
    "steps": [
        "-set appQuitOnError=true",
        "-importGlobalSettings {global_settings}",
        "-addFolder {input_folder}",
        "-align",
        "-selectMaximalComponent",
        "-renameSelectedComponent {scan_name}",
        "-setReconstructionRegionAuto",
        "-calculateNormalModel",
        "-renameSelectedModel {scan_name}_mesh_raw",
        "-selectMarginalTriangles",
        "-removeSelectedTriangles",
        "-renameSelectedModel {scan_name}_mesh",
        "-unwrap",
        "-calculateTexture",
        "-renameSelectedModel {scan_name}_textured",
        "-save {output_project}",
        "-exportReport {output_report} {overview_template}",
        "-quit"
    ]
}